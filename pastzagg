<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#0D0604">
<title>Pasticceria Zaggia Stra | Dolci Artigianali dal 2009 — Venezia</title>
<meta name="description" content="Pasticceria artigianale a Stra (VE) dal 2009. Brioche, millefoglie, bignè al pistacchio in Piazza Marconi, vicino Villa Pisani.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>

/* RESET E BASE */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}
html {
  scroll-behavior: smooth;
  scroll-padding-top: 80px;
  overflow-x: hidden;
  font-size: 16px;
}
body {
  font-family: 'Lato', sans-serif;
  background: #FDF8F0;
  color: #2A1505;
  overflow-x: hidden;
  cursor: default;
}
::selection { background: #C4873A; color: white; }
::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-track { background: #FDF8F0; }
::-webkit-scrollbar-thumb { background: #C4873A; }

/* VARIABILI */
:root {
  --espresso: #0D0604;
  --chocolate: #1C0F0A;
  --chocolate-mid: #2D1A0E;
  --cream: #FDF8F0;
  --cream-dark: #F5EDD8;
  --caramel: #C4873A;
  --caramel-light: #E8B97A;
  --caramel-dark: #8B5E25;
  --text-dark: #2A1505;
  --text-muted: #8B7355;
  --text-on-dark: rgba(253,248,240,0.88);
  --text-dim: rgba(253,248,240,0.42);
  --border-gold: rgba(196,135,58,0.22);
  --shadow-gold: 0 8px 32px rgba(196,135,58,0.32);
  --ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* KEYFRAMES */
@keyframes fadeUp {
  from { opacity:0; transform:translateY(32px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes fadeInLeft {
  from { opacity:0; transform:translateX(-48px); }
  to   { opacity:1; transform:translateX(0); }
}
@keyframes fadeInRight {
  from { opacity:0; transform:translateX(48px); }
  to   { opacity:1; transform:translateX(0); }
}
@keyframes growWidth {
  from { width:0; opacity:0; }
  to   { width:120px; opacity:1; }
}
@keyframes growHeight {
  from { height:0; opacity:0; }
  to   { height:100%; opacity:1; }
}
@keyframes growHeightScroll {
  from { height:0; }
  to   { height:52px; }
}
@keyframes float {
  0%,100% { transform:translateY(0); }
  50%      { transform:translateY(-14px); }
}
@keyframes shimmer {
  0%   { background-position: -300% center; }
  100% { background-position: 300% center; }
}
@keyframes pulse {
  0%,100% { box-shadow: 0 4px 20px rgba(196,135,58,0.35); }
  50%      { box-shadow: 0 4px 40px rgba(196,135,58,0.6),
                         0 0 0 8px rgba(196,135,58,0.08); }
}

/* SCROLL REVEAL */
.reveal {
  opacity:0;
  transform:translateY(28px);
  transition: opacity 0.8s var(--ease-expo),
              transform 0.8s var(--ease-expo);
}
.reveal.visible { opacity:1; transform:translateY(0); }
.reveal-left {
  opacity:0; transform:translateX(-32px);
  transition: opacity 0.8s var(--ease-expo),
              transform 0.8s var(--ease-expo);
}
.reveal-left.visible { opacity:1; transform:translateX(0); }
.reveal-right {
  opacity:0; transform:translateX(32px);
  transition: opacity 0.8s var(--ease-expo),
              transform 0.8s var(--ease-expo);
}
.reveal-right.visible { opacity:1; transform:translateX(0); }
.d1 { transition-delay:0.1s; }
.d2 { transition-delay:0.2s; }
.d3 { transition-delay:0.3s; }
.d4 { transition-delay:0.4s; }
.d5 { transition-delay:0.5s; }

.section-bar {
  height:1px;
  width:0;
  background: linear-gradient(90deg,#C4873A,#E8B97A,#C4873A);
  margin-top:18px;
  transition: width 1.3s var(--ease-expo);
}
.section-bar.visible { width:130px; }

/* ORNAMENT DIVIDER */
.ornament {
  display:flex; align-items:center; gap:18px;
  margin-bottom:70px;
}
.ornament-line {
  flex:1; height:1px;
  background: linear-gradient(90deg,transparent,
    rgba(196,135,58,0.35),transparent);
}
.ornament-dot { color:#C4873A; font-size:0.75rem; }

/* NAVBAR */
.navbar {
  position:fixed; top:0; left:0; right:0;
  z-index:1000;
  padding:26px 6%;
  display:flex; justify-content:space-between; align-items:center;
  transition: all 0.45s var(--ease-expo);
}
.navbar.scrolled {
  background: rgba(253,248,240,0.96);
  backdrop-filter: blur(24px) saturate(160%);
  padding: 16px 6%;
  border-bottom: 1px solid var(--border-gold);
  box-shadow: 0 4px 40px rgba(44,26,14,0.07);
}
.nav-logo { text-decoration:none; display:block; line-height:1; }
.logo-main {
  font-family:'Playfair Display',serif;
  font-style:italic; font-weight:700; font-size:1.65rem;
  background: linear-gradient(135deg,#FDF8F0 0%,#E8B97A 45%,#C4873A 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text; display:block; line-height:1.2;
  padding-bottom:0.15em; transition: background 0.45s;
}
.navbar.scrolled .logo-main {
  background: linear-gradient(135deg,#8B5E25,#C4873A);
  -webkit-background-clip:text; background-clip:text;
}
.logo-sub {
  font-family:'Lato',sans-serif; font-size:0.52rem;
  letter-spacing:0.24em; text-transform:uppercase;
  color:#C4873A; opacity:0.65; display:block; margin-top:5px;
}
.nav-links {
  display:flex; gap:36px; list-style:none;
}
.nav-links a {
  font-family:'Lato',sans-serif; font-size:0.68rem;
  letter-spacing:0.16em; text-transform:uppercase;
  color:rgba(253,248,240,0.72); text-decoration:none;
  position:relative; transition:color 0.3s;
}
.navbar.scrolled .nav-links a { color:#5C3D14; }
.nav-links a::after {
  content:''; position:absolute; bottom:-3px; left:0;
  width:0; height:1px; background:#C4873A;
  transition:width 0.3s ease;
}
.nav-links a:hover::after { width:100%; }
.nav-links a:hover { color:#C4873A; }
.nav-cta {
  display:inline-flex; align-items:center; gap:8px;
  font-family:'Lato',sans-serif; font-size:0.68rem;
  letter-spacing:0.14em; text-transform:uppercase;
  background:#C4873A; color:white;
  padding:12px 26px; border-radius:2px;
  text-decoration:none; position:relative; overflow:hidden;
  transition:transform 0.3s, box-shadow 0.3s;
}
.nav-cta::before {
  content:''; position:absolute; inset:0;
  background:#8B5E25; transform:translateX(-101%);
  transition:transform 0.35s var(--ease-expo);
}
.nav-cta:hover::before { transform:translateX(0); }
.nav-cta:hover {
  transform:translateY(-1px);
  box-shadow: var(--shadow-gold);
}
.nav-cta span, .nav-cta svg { position:relative; z-index:1; }
.hamburger {
  display:none; flex-direction:column; gap:5px;
  cursor:pointer; padding:8px; background:none; border:none;
  min-width:44px; min-height:44px;
  justify-content:center; align-items:center;
}
.hamburger span {
  display:block; width:22px; height:1.5px;
  background:white; border-radius:2px;
  transition:all 0.3s ease;
}
.navbar.scrolled .hamburger span { background:#2A1505; }

/* HERO */
#hero {
  min-height:100vh;
  min-height:100svh;
  background: var(--espresso);
  position:relative;
  overflow:hidden;
  display:grid;
  grid-template-columns: 55% 45%;
}

/* SFONDI */
.hero-bg {
  position:absolute; inset:0; z-index:0; pointer-events:none;
}
.hero-gradient {
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse 60% 70% at 20% 55%,
      rgba(196,135,58,0.16) 0%, transparent 60%),
    radial-gradient(ellipse 40% 50% at 75% 18%,
      rgba(196,135,58,0.08) 0%, transparent 55%),
    radial-gradient(ellipse 28% 35% at 88% 80%,
      rgba(196,135,58,0.05) 0%, transparent 50%);
}
.hero-grain {
  position:absolute; inset:0; opacity:0.042;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* LINEA VERTICALE */
.hero-vline {
  position:absolute; top:0; left:55%; z-index:1;
  width:1px; height:0;
  background:linear-gradient(180deg,
    transparent 0%,
    rgba(196,135,58,0.28) 15%,
    rgba(196,135,58,0.28) 85%,
    transparent 100%);
  animation: growHeight 1.2s var(--ease-expo) 0.9s forwards;
}

/* PARTICELLE */
.hero-particles { position:absolute; inset:0; z-index:1; pointer-events:none; }
.particle {
  position:absolute; border-radius:50%;
  background:#C4873A;
}
.p1 { width:7px;height:7px; top:17%;left:11%; opacity:0.10;
      animation:float 7s ease-in-out infinite; }
.p2 { width:4px;height:4px; top:65%;left:6%; opacity:0.07;
      animation:float 9.5s ease-in-out infinite 1.3s; }
.p3 { width:6px;height:6px; top:30%;left:48%; opacity:0.06;
      animation:float 11s ease-in-out infinite 2.2s; }
.p4 { width:3px;height:3px; top:80%;left:68%; opacity:0.08;
      animation:float 8s ease-in-out infinite 0.6s; }

/* LATO SINISTRO */
.hero-left {
  position:relative; z-index:2;
  display:flex; flex-direction:column; justify-content:center;
  padding:140px 5% 80px 8%;
  min-width:0; /* CRITICO: impedisce overflow */
}

.hero-eyebrow {
  font-family:'Lato',sans-serif;
  font-size:0.58rem; letter-spacing:0.42em;
  text-transform:uppercase; color:#C4873A;
  margin-bottom:22px;
  opacity:0;
  animation:fadeUp 0.7s var(--ease-expo) 0.3s forwards;
}
.hero-pre {
  font-family:'Lato',sans-serif;
  font-size:0.75rem; letter-spacing:0.5em;
  text-transform:uppercase;
  color:rgba(253,248,240,0.38);
  margin-bottom:6px;
  opacity:0;
  animation:fadeUp 0.7s var(--ease-expo) 0.45s forwards;
}

/* TITOLO — LA PARTE CRITICA */
.hero-title-wrap {
  overflow:visible;
  padding-bottom:0.2em;
  margin-bottom:24px;
}
.hero-title {
  font-family:'Playfair Display',serif;
  font-style:italic; font-weight:700;
  /* Dimensione sicura che non esce mai */
  font-size:clamp(4rem, 11vw, 11rem);
  line-height:1;
  padding-bottom:0.15em;
  letter-spacing:-0.02em;
  background:linear-gradient(135deg,#FDF8F0 0%,#E8B97A 40%,#C4873A 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text; background-size:250% auto;
  display:block;
  /* Impedisce overflow in qualsiasi caso */
  max-width:100%;
  word-break:keep-all;
  white-space:nowrap;
  opacity:0;
  animation:fadeInLeft 1.1s var(--ease-expo) 0.55s forwards,
            shimmer 5s linear 3s infinite;
}
.hero-gold-line {
  width:0; height:1px;
  background:linear-gradient(90deg,#C4873A,#E8B97A,#C4873A);
  margin-bottom:26px;
  animation:growWidth 1s var(--ease-expo) 1.1s forwards;
}
.hero-subtitle {
  font-family:'Playfair Display',serif;
  font-style:italic; font-weight:300;
  font-size:clamp(0.9rem, 1.8vw, 1.25rem);
  color:rgba(253,248,240,0.56); line-height:1.75;
  margin-bottom:40px; max-width:440px;
  opacity:0;
  animation:fadeUp 0.7s var(--ease-expo) 0.95s forwards;
}

/* BOTTONI — INLINE SU DESKTOP, COLONNA SU MOBILE */
.hero-buttons {
  display:flex; flex-wrap:wrap; gap:14px;
  margin-bottom:36px;
  opacity:0;
  animation:fadeUp 0.7s var(--ease-expo) 1.15s forwards;
}
.btn-primary {
  display:inline-flex; align-items:center; gap:9px;
  font-family:'Lato',sans-serif; font-size:0.7rem;
  letter-spacing:0.15em; text-transform:uppercase;
  background:#C4873A; color:white;
  padding:15px 32px; border-radius:2px;
  text-decoration:none; position:relative; overflow:hidden;
  transition:transform 0.3s, box-shadow 0.3s;
  white-space:nowrap;
}
.btn-primary::before {
  content:''; position:absolute; inset:0;
  background:#8B5E25; transform:translateX(-101%);
  transition:transform 0.35s var(--ease-expo);
}
.btn-primary:hover::before { transform:translateX(0); }
.btn-primary:hover {
  transform:translateY(-2px);
  box-shadow:0 8px 32px rgba(196,135,58,0.4);
}
.btn-primary span { position:relative; z-index:1; }
.btn-secondary {
  display:inline-flex; align-items:center; gap:9px;
  font-family:'Lato',sans-serif; font-size:0.7rem;
  letter-spacing:0.15em; text-transform:uppercase;
  background:transparent;
  border:1px solid rgba(196,135,58,0.42);
  color:rgba(253,248,240,0.78);
  padding:15px 32px; border-radius:2px;
  text-decoration:none; white-space:nowrap;
  transition:all 0.3s;
}
.btn-secondary:hover {
  border-color:#C4873A; color:white;
  background:rgba(196,135,58,0.1);
  transform:translateY(-2px);
}
.hero-hours-small {
  font-family:'Lato',sans-serif; font-size:0.68rem;
  color:rgba(253,248,240,0.32); letter-spacing:0.1em;
  opacity:0;
  animation:fadeUp 0.7s var(--ease-expo) 1.4s forwards;
}

/* LATO DESTRO */
.hero-right {
  position:relative; z-index:2;
  display:flex; flex-direction:column;
  justify-content:center; align-items:flex-start;
  padding:140px 7% 80px 6%;
  opacity:0;
  animation:fadeInRight 0.9s var(--ease-expo) 1.3s forwards;
}
.hero-info-box {
  border:1px solid rgba(196,135,58,0.22);
  border-radius:4px; padding:30px;
  background:rgba(253,248,240,0.04);
  width:100%; max-width:340px;
  margin-bottom:36px;
}
.info-box-year {
  font-family:'Playfair Display',serif;
  font-style:italic; font-size:2.4rem;
  color:#C4873A; line-height:1; display:block;
  margin-bottom:14px;
}
.info-box-divider {
  height:1px; background:rgba(196,135,58,0.28);
  margin-bottom:14px;
}
.info-box-text {
  font-family:'Lato',sans-serif; font-size:0.8rem;
  color:rgba(253,248,240,0.48); line-height:1.8;
}
.hero-stats { width:100%; max-width:340px; }
.hero-stat {
  padding:15px 0;
  border-bottom:1px solid rgba(196,135,58,0.14);
}
.hero-stat:first-child { border-top:1px solid rgba(196,135,58,0.14); }
.stat-num {
  font-family:'Playfair Display',serif;
  font-style:italic; font-size:1.6rem;
  color:#C4873A; line-height:1; display:block;
}
.stat-label {
  font-family:'Lato',sans-serif; font-size:0.53rem;
  letter-spacing:0.22em; text-transform:uppercase;
  color:rgba(253,248,240,0.38); display:block; margin-top:4px;
}

/* SCROLL INDICATOR */
.hero-scroll {
  position:absolute; bottom:36px; left:50%;
  transform:translateX(-50%); z-index:2;
  display:flex; flex-direction:column; align-items:center; gap:10px;
  opacity:0;
  animation:fadeUp 0.7s var(--ease-expo) 1.9s forwards;
}
.hero-scroll span {
  font-family:'Lato',sans-serif; font-size:0.56rem;
  letter-spacing:0.32em; text-transform:uppercase;
  color:rgba(253,248,240,0.28);
}
.scroll-line {
  width:1px; height:0;
  background:linear-gradient(180deg,#C4873A 0%,transparent 100%);
  animation:growHeightScroll 0.8s var(--ease-expo) 2.1s forwards;
}

/* BOTTONE FLOTTANTE TELEFONO */
.float-tel {
  position:fixed; bottom:30px; right:30px; z-index:999;
  width:56px; height:56px; border-radius:50%;
  background:#C4873A; display:flex;
  align-items:center; justify-content:center;
  text-decoration:none;
  animation:pulse 3s ease-in-out infinite;
  transition:transform 0.3s var(--ease-spring);
}
.float-tel:hover { transform:scale(1.1); }
.float-tel-label {
  position:absolute; right:68px;
  background:#1C0F0A; color:white;
  font-family:'Lato',sans-serif; font-size:0.7rem;
  white-space:nowrap; padding:7px 13px; border-radius:3px;
  opacity:0; transform:translateX(6px);
  transition:all 0.3s ease; pointer-events:none;
}
.float-tel:hover .float-tel-label {
  opacity:1; transform:translateX(0);
}

@media (max-width:1100px) {
  .hero-title { font-size:clamp(3.5rem,9vw,9rem); }
}

@media (max-width:900px) {
  /* NAVBAR */
  .navbar { padding:18px 24px; }
  .navbar.scrolled { padding:14px 24px; }
  .nav-links { display:none; }
  .hamburger { display:flex; }
  .nav-links.open {
    display:flex; flex-direction:column;
    position:fixed; inset:0; z-index:998;
    background:rgba(13,6,4,0.97);
    align-items:center; justify-content:center;
    gap:38px;
  }
  .nav-links.open a {
    font-size:1.05rem; color:rgba(253,248,240,0.82);
    letter-spacing:0.14em;
  }
  .nav-cta { display:none; }

  /* HERO MOBILE */
  #hero {
    grid-template-columns:1fr;
    min-height:100svh;
  }
  .hero-vline { display:none; }
  .hero-left {
    padding:120px 24px 50px;
    justify-content:flex-end;
  }
  .hero-title {
    font-size:clamp(3.8rem,16vw,7rem);
    white-space:normal;
    word-break:break-word;
  }
  .hero-buttons {
    flex-direction:column;
    align-items:stretch;
  }
  .btn-primary, .btn-secondary {
    justify-content:center;
    width:100%;
  }
  .hero-right {
    display:none;
  }
  .p3,.p4 { display:none; }
  .float-tel { bottom:20px; right:20px; width:50px; height:50px; }
}

@media (max-width:480px) {
  .hero-left { padding:110px 18px 44px; }
  .hero-title { font-size:clamp(3.2rem,14vw,5.5rem); }
  .hero-subtitle { font-size:0.88rem; }
  .hero-eyebrow { font-size:0.52rem; letter-spacing:0.3em; }
}

#storia {
  background: #FDF8F0;
  padding: 130px 8%;
  position: relative;
  overflow: hidden;
}
#storia::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: 0.025;
  pointer-events: none;
}
.storia-ornament {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 80px;
  max-width: 1400px;
  margin-left: auto;
  margin-right: auto;
}
.storia-ornament::before,
.storia-ornament::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg,
    transparent, rgba(196,135,58,0.35), transparent);
}
.storia-ornament span {
  color: #C4873A;
  font-size: 0.72rem;
}
.storia-inner {
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 58% 42%;
  gap: 80px;
  align-items: center;
}
.storia-eyebrow {
  font-family: 'Lato', sans-serif;
  font-size: 0.58rem;
  letter-spacing: 0.42em;
  text-transform: uppercase;
  color: #C4873A;
  display: block;
  margin-bottom: 18px;
}
.storia-title {
  font-family: 'Playfair Display', serif;
  font-weight: 400;
  font-size: clamp(2.4rem, 4.5vw, 4.5rem);
  line-height: 1.08;
  color: #2A1505;
  margin-bottom: 20px;
}
.storia-title em {
  font-style: italic;
  color: #C4873A;
}
.storia-bar {
  height: 1px;
  width: 0;
  background: linear-gradient(90deg, #C4873A, #E8B97A, #C4873A);
  margin-bottom: 36px;
  transition: width 1.3s cubic-bezier(0.16,1,0.3,1);
}
.storia-bar.visible { width: 130px; }
.storia-p1 {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-weight: 300;
  font-size: clamp(1rem, 1.6vw, 1.18rem);
  line-height: 1.85;
  color: #5C3D14;
  margin-bottom: 22px;
}
